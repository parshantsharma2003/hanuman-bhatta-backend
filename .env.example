NODE_ENV=development
PORT=5000
API_VERSION=v1

# Comma-separated list for multiple origins
CORS_ORIGIN=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/hanuman-bhatta

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=12h
AUTH_COOKIE_NAME=hb_admin_token
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_NAME=Hanuman Bhatta Admin

# Contact
WHATSAPP_NUMBER=919999999999
CONTACT_EMAIL=contact@example.com
CONTACT_PHONE=9999999999

# Business
BRICKS_PER_TROLLEY=3000
WASTAGE_PERCENTAGE=5

# Cloudinary (optional, required for gallery uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

