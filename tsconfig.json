{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "lib": ["ES2020"],
    "types": ["node"],

    "outDir": "./dist",
    "rootDir": "./src",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",

    "allowSyntheticDefaultImports": true,

    "sourceMap": true,
    "removeComments": true,

    // ✅ ADD THIS (important for stability)
    "noImplicitAny": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}